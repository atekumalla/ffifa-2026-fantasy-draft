# ===========================================
# FIFA 2026 Fantasy Draft - Environment Config
# ===========================================
# All secrets are passed via environment variables.
# No credentials files need to be committed to the repo.

# --- Google Sheets ---
# The spreadsheet ID (from the Google Sheets URL)
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# OPTION 1 (Recommended for hosted services like Render):
# Paste the ENTIRE contents of your service account JSON as a single-line string.
# To convert your credentials.json to a single line:
#   cat credentials.json | jq -c .
# Then paste the output here:
GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# OPTION 2 (Local development only):
# Path to the credentials JSON file on disk
# GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json

# --- Football Data API ---
# Free tier: https://www.football-data.org/client/register
# 10 requests/minute, covers World Cup
FOOTBALL_API_KEY=your_football_data_api_key_here

# --- OpenAI API (ChatGPT fallback) ---
# Used when football API is unavailable
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Sync Schedule ---
# Daily auto-sync time (24h format)
SYNC_HOUR=6
SYNC_MINUTE=0
SYNC_TIMEZONE=Asia/Kolkata

# --- State ---
# On Render/hosted: use /tmp for ephemeral storage or a persistent disk path
# STATE_FILE=/tmp/last_sync.json

# --- Deployment ---
PORT=8000

# --- Logging ---
LOG_LEVEL=INFO
